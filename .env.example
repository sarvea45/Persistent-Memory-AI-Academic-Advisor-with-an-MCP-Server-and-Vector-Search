# Path for the SQLite database file inside the container
DB_PATH=/app/data/advisor_memory.db

# Path for the ChromaDB persistence directory inside the container
CHROMA_DB_PATH=/app/data/chroma_db

# Model to use for sentence embeddings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# URL of the MCP server (used by the agent service)
MCP_SERVER_URL=http://mcp_server:8000

# Optional: For agents using the Claude API
# CLAUDE_API_KEY=your_claude_api_key_here

# Optional: For agents using Ollama (local LLM)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3
